<Window x:Class="EstoqueInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EstoqueInterface"
        mc:Ignorable="d"
        Title="Interface de Estoque de Vendas" Height="450" Width="800">

    <TabControl>

        <TabItem Header="Dados dos Produtos" >
            <StackPanel>

                <TextBlock Text="Itens em Estoque:" Margin="6"></TextBlock>
                <ScrollViewer Margin="6">
                    <ListBox Margin="6" Height="210" ItemsSource="{Binding Itens}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat={}{0}°C}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <Button Content="Salvar" Margin="6" Padding="8" Command="{Binding SalvarCommand}" />

            </StackPanel>
        </TabItem>

    </TabControl>
</Window>
